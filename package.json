    "eslint-plugin-react-hooks": "5.1.0",
    "jest": "30.2.0",
    "jest-environment-jsdom": "30.2.0",
    "prettier": "3.4.2",
    "ts-node": "10.9.2"
  },
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": "24.15.0"
