    "@mui/material": "6.3.0",
    "@mui/material-nextjs": "6.3.0",
    "@mui/x-charts": "8.11.2",
    "@next/third-parties": "16.2.6",
    "@reduxjs/toolkit": "2.5.0",
    "@sentry/nextjs": "10.51.0",
    "@types/node": "22.10.4",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "clsx": "2.1.1",
